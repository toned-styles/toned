{
  "name": "@toned/core",
  "version": "0.2.0",
  "author": "Kenzhaev Artur",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./index.js",
    "./dom": "./dom/index.js",
    "./types": "./types/index.js",
    "./stylesheet": "./stylesheet/index.js",
    "./system": "./system/index.js",
    "./utils": "./utils/index.js",
    "./vite": "./vite/index.js"
  },
  "publishConfig": {
    "access": "public",
    "directory": ".dist",
    "linkDirectory": false
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lttb/toned.git",
    "directory": "@toned/core"
  },
  "scripts": {
    "prepublishOnly": "bun run build",
    "build": "bun --bun -e 'import(`@config/build`)'"
  },
  "peerDependencies": {
    "vite": ">=5"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@config/build": "workspace:*",
    "@config/typescript": "workspace:*",
    "vite": "^6.3.5"
  }
}
